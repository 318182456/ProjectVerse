{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["DOM", "ES5", "ES6", "ES7", "DOM.Iterable"],
    "moduleResolution": "node",
    "strict": true
  },
  "include": ["**/*.ts"]
}
